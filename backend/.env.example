PORT=8080
DATABASE_DSN=nextmarket:nextmarket@tcp(127.0.0.1:3306)/nextmarket?parseTime=true&multiStatements=true
JWT_SECRET=replace-with-long-random-secret
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ALLOWED_ORIGIN=http://localhost:5173

# Cloud Run / Cloud SQL alternative settings
# DATABASE_DSN の代わりに以下でも接続できます
# DB_USER=nextmarket
# DB_PASS=nextmarket
# DB_NAME=nextmarket
# INSTANCE_UNIX_SOCKET=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# DB_HOST=127.0.0.1
# DB_PORT=3306
